# CMDLY environment variables — copy to .env.local and fill in values

# Authentication
BETTER_AUTH_SECRET=

# Database
DATABASE_URL=

# LLM provider (openai | anthropic | ollama)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Infrastructure
PROXMOX_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
WAZUH_URL=
WAZUH_USERNAME=
WAZUH_PASSWORD=
ZABBIX_URL=
ZABBIX_TOKEN=
