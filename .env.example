# CMDLY environment variables — copy to .env and fill in values

DATABASE_URL=postgresql://user:pass@localhost:5432/cmdly
BETTER_AUTH_SECRET=change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# LLM provider (openai | anthropic | ollama)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Infrastructure
PROXMOX_URL=
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=
WAZUH_URL=
WAZUH_USERNAME=
WAZUH_PASSWORD=
ZABBIX_URL=
ZABBIX_TOKEN=
